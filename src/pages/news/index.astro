---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import NewsCard from '../../components/NewsCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('news', n => !n.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured  = allNews[0];
const remaining = allNews.slice(1);
---

<Layout title="News" description="Latest news and updates from the FORT Lab.">

  <PageHero eyebrow="Latest Updates" title="News" />

  <div class="content surface-light">
    <div class="section-inner">

      {allNews.length === 0 && <EmptyState />}

      {featured && (
        <div class="featured-wrap">
          <p class="section-tag">Featured</p>
          <NewsCard item={featured} featured />
        </div>
      )}

      {remaining.length > 0 && (
        <div class="grid-wrap">
          {featured && <p class="section-tag">More News</p>}
          <div class="news-grid">
            {remaining.map(item => <NewsCard item={item} />)}
          </div>
        </div>
      )}

    </div>
  </div>

</Layout>

<style>
  .content {
    background: #f8fafc;
    padding: var(--space-12) 0;
  }

  .section-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-link);
    margin: 0 0 var(--space-4);
  }

  .featured-wrap {
    margin-bottom: var(--space-12);
  }

  .grid-wrap {}

  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  @media (max-width: 640px) {
    .news-grid { grid-template-columns: 1fr; }
  }
</style>
