---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import NewsCard from '../../components/NewsCard.astro';
import EmptyState from '../../components/EmptyState.astro';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('news', n => !n.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Use the item flagged featured: true as the hero; fall back to most-recent
const featured  = allNews.find(n => n.data.featured) ?? allNews[0];
const remaining = allNews.filter(n => n !== featured);
---

<Layout title="News" description="Latest news and updates from the FORT Lab.">

  <PageHero eyebrow="Latest Updates" title="News" />

  <div class="content">
    <div class="section-inner">

      {allNews.length === 0 && <EmptyState />}

      {featured && (
        <div class="featured-wrap">
          <p class="section-label">Featured</p>
          <NewsCard item={featured} featured />
        </div>
      )}

      {remaining.length > 0 && (
        <div class="grid-wrap">
          <p class="grid-label">Latest News</p>
          <div class="news-grid">
            {remaining.map(item => <NewsCard item={item} />)}
          </div>
        </div>
      )}

    </div>
  </div>

</Layout>

<style>
  .content {
    background: #eef3f5;
    padding: var(--space-2) 0 var(--space-16);
  }

  .featured-wrap {
    margin-bottom: var(--space-12);
  }

  .section-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-link);
    margin: 0 0 var(--space-4);
  }

  .grid-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-link);
    margin: 0 0 var(--space-5);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  @media (max-width: 900px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .news-grid { grid-template-columns: 1fr; }
  }
</style>
