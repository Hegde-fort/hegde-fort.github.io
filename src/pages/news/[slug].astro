---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  // Only generate pages for items WITHOUT an externalUrl
  const items = await getCollection('news', n => !n.data.draft && !n.data.externalUrl);
  return items.map(item => ({
    params: { slug: item.id },
    props:  { item },
  }));
}

const { item } = Astro.props;
const { title, date, summary, image, imageAlt } = item.data;
const { Content } = await render(item);

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={summary}>

  <article class="news-article">
    <header class="article-header">
      <a class="back-link" href="/news">← All News</a>
      <time datetime={date.toISOString()} class="date">{formattedDate}</time>
      <h1>{title}</h1>
      <p class="summary">{summary}</p>
    </header>

    {image && (
      <Image class="hero-image" src={image} alt={imageAlt || title} />
    )}

    <div class="article-body">
      <Content />
    </div>
  </article>

</Layout>

<style>
  .news-article {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-12) var(--content-pad-x);
  }

  @media (max-width: 700px) {
    .news-article {
      padding-top: var(--space-6);
      padding-left: var(--content-pad-x);
      padding-right: var(--content-pad-x);
    }
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    opacity: 0.7;
  }

  .back-link:hover { opacity: 1; }

  .date {
    display: block;
    font-size: 0.85rem;
    opacity: 0.6;
    margin-bottom: 0.5rem;
  }

  .article-header h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.3;
  }

  .summary {
    font-size: 1.05rem;
    opacity: 0.75;
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .hero-image {
    width: 100%;
    border-radius: 8px;
    margin-bottom: 2rem;
    max-height: 400px;
    object-fit: cover;
  }

  .article-body {
    line-height: 1.75;
    font-size: 1rem;
  }

  .article-body h2, .article-body h3 { margin-top: 2rem; }
  .article-body p  { margin-bottom: 1.25rem; }
  .article-body a  { text-decoration: underline; }
</style>
