---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', p => !p.data.draft);

const byStartDesc = (a: typeof allProjects[0], b: typeof allProjects[0]) =>
  b.data.startDate.getTime() - a.data.startDate.getTime();

const byEndDesc = (a: typeof allProjects[0], b: typeof allProjects[0]) => {
  const aEnd = a.data.endDate ?? a.data.startDate;
  const bEnd = b.data.endDate ?? b.data.startDate;
  return bEnd.getTime() - aEnd.getTime();
};

const active    = allProjects.filter(p => p.data.status === 'active')   .sort(byStartDesc);
const completed = allProjects.filter(p => p.data.status === 'completed').sort(byEndDesc);
const archived  = allProjects.filter(p => p.data.status === 'archived') .sort(byEndDesc);

type Accent = 'yellow' | 'blue' | 'gray';
const groups = (
  [
    { label: 'Active Projects',    accent: 'yellow' as Accent, items: active    },
    { label: 'Completed Projects', accent: 'blue'   as Accent, items: completed },
    { label: 'Archived',           accent: 'gray'   as Accent, items: archived  },
  ] as const
).filter(g => g.items.length > 0);
---

<Layout title="Projects" description="Research projects from the FORT Lab.">

  <PageHero eyebrow="Research" title="Projects">
    <p class="hero-meta">
      {active.length > 0 && `${active.length} active`}
      {active.length > 0 && completed.length > 0 && ' · '}
      {completed.length > 0 && `${completed.length} completed`}
    </p>
  </PageHero>

  <div class="content surface-light">
    <div class="section-inner">

      {groups.length === 0 && <EmptyState />}

      {groups.map(group => (
        <div class="group">
          <div class="group-header">
            <span class:list={['group-dot', `dot-${group.accent}`]}></span>
            <h2 class="group-title">{group.label}</h2>
          </div>
          <div class="project-grid">
            {group.items.map(project => (
              <ProjectCard project={project} accent={group.accent} />
            ))}
          </div>
        </div>
      ))}

    </div>
  </div>

</Layout>

<style>
  .hero-meta {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .content {
    background: #f8fafc;
    padding: var(--space-12) 0;
  }

  .group {
    margin-bottom: var(--space-12);
  }
  .group:last-child { margin-bottom: 0; }

  .group-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .group-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-yellow { background: var(--color-accent); }
  .dot-blue   { background: var(--color-link); }
  .dot-gray   { background: rgba(15, 23, 42, 0.25); }

  .group-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.01em;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }


  @media (max-width: 640px) {
    .project-grid { grid-template-columns: 1fr; }
  }
</style>
