---
import Layout from '../layouts/Layout.astro';
import TeamCard from '../components/TeamCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { getCollection } from 'astro:content';
import { ROLE_ORDER, ROLE_LABELS_PLURAL } from '../lib/team';

const allMembers = await getCollection('team', m => !m.data.draft);

const alpha = (a: { data: { name: string } }, b: { data: { name: string } }) =>
  a.data.name.localeCompare(b.data.name);

const MONTH_MAP: Record<string, string> = {
  january: '01', february: '02', march: '03', april: '04',
  may: '05', june: '06', july: '07', august: '08',
  september: '09', october: '10', november: '11', december: '12',
  winter: '01', spring: '03', summer: '06', fall: '09', autumn: '09',
};

function toSortKey(dateStr?: string): string {
  if (!dateStr) return '';
  const parts = dateStr.trim().toLowerCase().split(/\s+/);
  if (parts.length === 2) {
    const month = MONTH_MAP[parts[0]];
    if (month) return `${parts[1]}-${month}`;
  }
  return dateStr;
}

const byEndDateDesc = (
  a: { data: { endDate?: string; startDate?: string } },
  b: { data: { endDate?: string; startDate?: string } },
) => {
  const aKey = toSortKey(a.data.endDate ?? a.data.startDate);
  const bKey = toSortKey(b.data.endDate ?? b.data.startDate);
  return bKey.localeCompare(aKey);
};

const active = allMembers.filter(m => !m.data.alumni);
const alumni = allMembers.filter(m =>  m.data.alumni);

const activeGrouped = ROLE_ORDER
  .map(role => ({
    role,
    members: active.filter(m => m.data.role === role).sort(alpha),
  }))
  .filter(g => g.members.length > 0);

const alumniGrouped = ROLE_ORDER
  .map(role => ({
    role,
    members: alumni.filter(m => m.data.role === role).sort(byEndDateDesc),
  }))
  .filter(g => g.members.length > 0);

// Group photos shown in the hero strip
const heroPhotos = [
  { src: '/images/teamPhotos/IMG_2323.jpg',                   alt: 'FORT Lab team' },
  { src: '/images/teamPhotos/Summer2022_teamlunch.jpg',       alt: 'Team lunch, Summer 2022' },
  { src: '/images/teamPhotos/PXL_20250411_210215580.jpg',     alt: 'FORT Lab team 2025' },
];
---

<Layout title="Team" description="Meet the members of the FORT Lab.">

  <!-- ── Hero strip ─────────────────────────────────────────── -->
  <section class="hero">
    <div class="photo-strip">
      {heroPhotos.map((p, i) => (
        <div class:list={['photo-frame', `photo-frame--${i}`]}>
          <img src={p.src} alt={p.alt} />
        </div>
      ))}
    </div>
    <div class="hero-title-wrap">
      <h1 class="hero-heading">Meet the FORT Lab!</h1>
      <div class="hero-underline" aria-hidden="true"></div>
    </div>
  </section>

  <!-- ── Active members ─────────────────────────────────────── -->
  <div class="content surface-light">
    <div class="section-inner">

      {allMembers.length === 0 && <EmptyState />}

      {activeGrouped.map(({ role, members }) => (
        <section class="role-section">
          <h2 class="role-heading">{ROLE_LABELS_PLURAL[role] ?? role}</h2>
          <div class="group-box">
            <div class="member-grid">
              {members.map(m => <TeamCard member={m} />)}
            </div>
          </div>
        </section>
      ))}

      <!-- ── Alumni ────────────────────────────────────────── -->
      {alumniGrouped.length > 0 && (
        <section class="role-section alumni-section">
          <h2 class="role-heading">Alumni</h2>
          <div class="group-box">
            {alumniGrouped.map(({ role, members }) => (
              <div class="alumni-group">
                <h3 class="alumni-role">{ROLE_LABELS_PLURAL[role] ?? role}</h3>
                <div class="member-grid">
                  {members.map(m => <TeamCard member={m} />)}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

    </div>
  </div>

</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .hero {
    background: var(--color-bg-dark);
    padding: var(--space-12) var(--content-pad-x) var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }

  /* Photo strip */
  .photo-strip {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .photo-frame {
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 4px solid #ffffff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
  }

  /* Rotations matching the mockup: left tilts left, center straight, right tilts right */
  .photo-frame--0 { transform: rotate(-5deg); width: 210px; height: 155px; }
  .photo-frame--1 { transform: rotate(0deg) translateY(-24px); width: 280px; height: 200px; z-index: 1; }
  .photo-frame--2 { transform: rotate( 4deg); width: 210px; height: 155px; }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Heading + underline */
  .hero-title-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .hero-heading {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    font-style: normal;
    color: #ffffff;
    margin: 0;
    text-align: center;
  }

  /* Short golden bar under the heading */
  .hero-underline {
    width: 80px;
    height: 3px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
  }

  /* ── Content area ───────────────────────────────────────────── */
  .content {
    background: #d7e2e4;
  }

  /* ── Role sections ──────────────────────────────────────────── */
  .role-section {
    margin-bottom: var(--space-12);
  }

  .role-section:last-child { margin-bottom: 0; }

  /* Heading floats just above the box */
  .role-heading {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-link);
    text-align: left;
    margin: 0 0 var(--space-2);
    padding: 0;
    border: none;
  }

  /* Bounded box wrapping all cards in the group */
  .group-box {
    border: 1.5px solid rgba(18, 63, 84, 0.15);
    border-radius: var(--radius-card);
    padding: var(--space-8);
    background: #ffffff;
  }

  /* All other roles — 2-column responsive grid */
  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    column-gap: var(--space-8);
    row-gap: 0;
  }

  /* ── Alumni ─────────────────────────────────────────────────── */
  .alumni-section { margin-top: var(--space-4); }

  .alumni-group { margin-bottom: 0; }

  .alumni-group + .alumni-group {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .alumni-role {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(15, 23, 42, 0.45);
    margin: 0 0 var(--space-3);
  }

  @media (max-width: 640px) {
    .photo-frame--0,
    .photo-frame--2 { display: none; }
    .photo-frame--1 { width: 100%; max-width: 320px; height: 220px; transform: none; }

    .group-box { padding: var(--space-4); }
    .member-grid { grid-template-columns: 1fr; }
    .role-heading { font-size: 1.1rem; }
  }
</style>
