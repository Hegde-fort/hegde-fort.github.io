---
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import NewsCard from '../components/NewsCard.astro';
import Button from '../components/Button.astro';
import { getCollection, getEntry } from 'astro:content';

const lab = (await getEntry('site', 'lab'))!.data;

const featuredPubs = (await getCollection('publications', p => !p.data.draft && p.data.featured))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const featuredNews = (await getCollection('news', n => !n.data.draft && n.data.featured))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="Home">

  <!-- ── HERO ───────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="lab-label">{lab.name}</p>
        <h1>{lab.hero.headline}</h1>
        <p class="hero-sub">{lab.hero.description}</p>
        <Button href="/about">Learn More</Button>
      </div>

      <div class="hero-aside">
        <div class="news-preview">
          <h2>News</h2>
          {featuredNews.map(item => <NewsCard item={item} compact={true} />)}
          <Button href="/news" fullWidth={true}>Browse All News</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED PUBLICATIONS ─────────────────────────── -->
  <section class="section publication-section">
    <div class="section-inner">
      <h2 class="section-title">Publications</h2>
      <Button href="/publications" variant="outline">Browse All</Button>
      <div class="pub-list">
        {featuredPubs.map(pub => <PublicationCard pub={pub} />)}
      </div>
    </div>
  </section>

  <!-- ── JOIN CTA ───────────────────────────────────────── -->
  <section class="section join-section">
    <div class="section-inner join-inner">
      <div class="join-text">
        <p class="label">Joining</p>
        <h2>{lab.joining.headline}</h2>
        {lab.joining.blurb && <p>{lab.joining.blurb}</p>}
        <div class="join-buttons">
          <Button href="/team" variant="outline">Meet Our Team</Button>
        </div>
      </div>

      <!-- TODO: replace with real lab group photo in public/images/ -->
      <div class="join-photo-placeholder">Lab photo goes here</div>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .hero {
    margin-top: calc(-1 * var(--nav-height));
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 4rem;
    background: url('/images/HeroBackground.png') center/cover no-repeat;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-pad-x);
  }

  .lab-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.75rem;
    color: var(--color-accent);
  }

  .hero-text h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .hero-sub {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.75rem;
    color: var(--color-text-muted);
  }

  /* ── News preview panel ────────────────────────────────────── */
  .news-preview {
    background: var(--color-bg-panel);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);

    /* Override CSS var tokens so child components use dark text */
    color: #0f172a;
    --color-text-primary:  #0f172a;
    --color-text-muted:    rgba(15, 23, 42, 0.55);
    --color-border:        rgba(15, 23, 42, 0.12);
    --color-bg-subtle:     rgba(15, 23, 42, 0.05);
  }

  .news-preview :global(.news-card + .news-card) {
    margin-top: var(--space-3);
  }

  .news-preview h2 {
    margin: 0 0 var(--space-4);
    font-size: 1.4rem;
    font-weight: 800;
    text-align: center;
    letter-spacing: 0.04em;
    color: #0f172a;
  }

  .news-preview :global(.btn--full) {
    margin-top: var(--space-4);
  }

  /* ── Sections ──────────────────────────────────────────────── */
  .section {
    border-top: 1px solid var(--color-border);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--content-pad-x);
  }

  .section-title { margin: 0 0 0.5rem; }

  .publication-section {
    background: var(--color-bg-surface);
    border-top: none;

    /* Override CSS var tokens so child components use dark text */
    color: #0f172a;
    --color-text-primary:  #0f172a;
    --color-text-muted:    rgba(15, 23, 42, 0.55);
    --color-border:        rgba(15, 23, 42, 0.1);
    --color-bg-subtle:     rgba(15, 23, 42, 0.05);
    --color-accent:        #c49a00;
  }

  .pub-list { margin-top: 1.5rem; }

  /* ── Join CTA ──────────────────────────────────────────────── */
  .join-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem;
    color: var(--color-accent);
  }

  .join-text h2 { margin: 0 0 1rem; }

  .join-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .join-photo-placeholder {
    background: var(--color-bg-subtle);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-border);
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 700px) {
    .hero-inner, .join-inner { grid-template-columns: 1fr; }
  }
</style>
