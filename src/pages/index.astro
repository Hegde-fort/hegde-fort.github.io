---
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection, getEntry } from 'astro:content';

const lab = (await getEntry('site', 'lab'))!.data;

const featuredPubs = (await getCollection('publications', p => !p.data.draft && p.data.featured))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const featuredNews = (await getCollection('news', n => !n.data.draft && n.data.featured))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Layout title="Home">

  <!-- ── HERO ───────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-text">
      <p class="lab-label">{lab.name}</p>
      <h1>{lab.hero.headline}</h1>
      <p class="hero-sub">{lab.hero.description}</p>
      <a class="btn" href="/about">Learn More</a>
    </div>

    <div class="hero-aside">
      <div class="news-preview">
        <h2>News</h2>
        {featuredNews.map(item => <NewsCard item={item} />)}
        <a class="btn-outline" href="/news">Browse All News</a>
      </div>
    </div>
  </section>

  <!-- ── FEATURED PUBLICATIONS ─────────────────────────── -->
  <section class="section publication-section">
    <div class="section-inner">
      <h2 class="section-title">Publications</h2>
      <a class="btn-outline" href="/publications">Browse All</a>
      <div class="pub-list">
        {featuredPubs.map(pub => <PublicationCard pub={pub} />)}
      </div>
    </div>
  </section>

  <!-- ── JOIN CTA ───────────────────────────────────────── -->
  <section class="section join-section">
    <div class="section-inner join-inner">
      <div class="join-text">
        <p class="label">Joining</p>
        <h2>{lab.joining.headline}</h2>
        {lab.joining.blurb && <p>{lab.joining.blurb}</p>}
        <div class="join-buttons">
          <a class="btn-outline" href="/team">Meet Our Team</a>
        </div>
      </div>

      <!-- TODO: replace with real lab group photo in public/images/ -->
      <div class="join-photo-placeholder">Lab photo goes here</div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    /* pull hero up so it starts at the very top, behind the fixed nav */
    margin-top: calc(-1 * var(--nav-height));
    padding: calc(var(--nav-height) + 4rem) var(--content-pad-x) 4rem;
    background: red;
  }

  .lab-label {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
  }

  .hero-text h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .hero-sub {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.5rem;
  }

  .news-preview h2 { margin-top: 0; }

  .section {
    border-top: 1px solid var(--color-border);
  }

  .section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--content-pad-x);
  }

  .section-title { margin: 0 0 0.5rem; }

  .publication-section {
    background: orange;
  }

  .pub-list { margin-top: 1.5rem; }

  .join-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem;
  }

  .join-text h2 { margin: 0 0 1rem; }

  .join-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .join-photo-placeholder {
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 700px) {
    .hero, .join-inner { grid-template-columns: 1fr; }
  }
</style>
