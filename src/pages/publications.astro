---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import PublicationCard from '../components/PublicationCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { getCollection } from 'astro:content';

const allPubs = await getCollection('publications', p => !p.data.draft);
const sorted  = allPubs.sort((a, b) => b.data.year - a.data.year);
const years   = [...new Set(sorted.map(p => p.data.year))];
const byYear  = years.map(year => ({ year, pubs: sorted.filter(p => p.data.year === year) }));
---

<Layout title="Publications" description="Research publications from the FORT Lab.">

  <PageHero eyebrow="Research Output" title="Publications" />

  {allPubs.length === 0 ? (
    <div class="content surface-light">
      <div class="section-inner">
        <EmptyState />
      </div>
    </div>
  ) : (
    <>
      <!-- Year filter bar -->
      <div class="filter-bar surface-light">
        <div class="section-inner filter-inner">
          <span class="filter-label">Filter by year</span>
          <div class="year-pills" id="year-pills">
            <button class="year-pill active" data-year="all">All</button>
            {years.map(y => (
              <button class="year-pill" data-year={String(y)}>{y}</button>
            ))}
          </div>
        </div>
      </div>

      <div class="content surface-light">
        <div class="section-inner">
          {byYear.map(({ year, pubs }) => (
            <div class="year-block" data-year-block={String(year)}>
              <div class="year-marker">
                <span class="year-num">{year}</span>
              </div>
              <div class="year-pubs">
                {pubs.map(pub => <PublicationCard pub={pub} />)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </>
  )}

</Layout>

<script>
  function initFilter() {
    const pills   = document.querySelectorAll<HTMLButtonElement>('#year-pills .year-pill');
    const blocks  = document.querySelectorAll<HTMLElement>('[data-year-block]');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');

        const target = pill.dataset.year!;
        blocks.forEach(block => {
          block.style.display =
            target === 'all' || block.dataset.yearBlock === target ? '' : 'none';
        });
      });
    });
  }

  initFilter();
  document.addEventListener('astro:after-swap', initFilter);
</script>

<style>
  /* ── Filter bar ──────────────────────────────────────────── */
  .filter-bar {
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    padding: var(--space-4) 0;
    position: sticky;
    top: var(--nav-height);
    z-index: 10;
    background: #f8fafc;
  }

  .filter-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(15, 23, 42, 0.4);
    white-space: nowrap;
  }

  .year-pills {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .year-pill {
    all: unset;
    box-sizing: border-box;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-full);
    border: 1.5px solid rgba(15, 23, 42, 0.15);
    color: rgba(15, 23, 42, 0.55);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .year-pill:hover {
    border-color: var(--color-accent);
    color: #0f172a;
  }

  .year-pill.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #0f172a;
  }

  /* ── Content ────────────────────────────────────────────── */
  .content {
    background: #f8fafc;
    padding-bottom: var(--space-16);
  }

  .year-block {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-8);
    padding: var(--space-10) 0;
    border-bottom: 1px solid rgba(15, 23, 42, 0.07);
  }

  .year-block:last-child { border-bottom: none; }

  .year-marker {
    padding-top: var(--space-4);
    text-align: right;
  }

  .year-num {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-link);
    letter-spacing: -0.02em;
    display: block;
    position: sticky;
    top: calc(var(--nav-height) + 60px);
  }

  .year-pubs {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 600px) {
    .year-block { grid-template-columns: 1fr; gap: var(--space-2); }
    .year-marker { text-align: left; padding-top: 0; }
    .year-num { position: static; }
  }
</style>
