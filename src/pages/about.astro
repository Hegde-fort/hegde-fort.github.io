---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const lab = (await getEntry('site', 'lab'))!.data;
---

<Layout
  title="About Us"
  description={lab.about.tagline ?? lab.description}
>

  <section class="page-header">
    <h1>About Us</h1>
    {lab.about.tagline && <p class="subtitle">{lab.about.tagline}</p>}
  </section>

  <!-- ── MISSION ──────────────────────────────────────── -->
  {lab.about.mission && (
    <section class="section">
      <h2>Our Mission</h2>
      {lab.about.mission.trim().split('\n\n').map(para => (
        <p>{para.trim()}</p>
      ))}
    </section>
  )}

  <!-- ── RESEARCH AREAS ───────────────────────────────── -->
  {lab.researchAreas.length > 0 && (
    <section class="section">
      <h2>Research Areas</h2>
      <ul class="research-areas">
        {lab.researchAreas.map(area => (
          <li><strong>{area.name}</strong> — {area.description}</li>
        ))}
      </ul>
    </section>
  )}

  <!-- ── AFFILIATIONS ──────────────────────────────────── -->
  {lab.affiliations.length > 0 && (
    <section class="section">
      <h2>Affiliations</h2>
      <ul class="affiliations">
        {lab.affiliations.map(a => <li>{a}</li>)}
      </ul>
    </section>
  )}

  <!-- ── CONTACT ───────────────────────────────────────── -->
  {(lab.contact?.address || lab.contact?.officeHours) && (
    <section class="section">
      <h2>Contact</h2>
      {lab.contact.address    && <p>{lab.contact.address}</p>}
      {lab.contact.officeHours && <p>Office hours: {lab.contact.officeHours}</p>}
    </section>
  )}

</Layout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .page-header h1 { margin: 0 0 0.5rem; }

  .subtitle {
    font-size: 1.1rem;
    margin: 0;
    opacity: 0.7;
  }

  .section {
    padding: 2.5rem 0;
    border-bottom: 1px solid #e5e7eb;
    max-width: 720px;
  }

  .section h2 { margin-top: 0; }

  .section p { line-height: 1.75; }

  .research-areas, .affiliations {
    padding-left: 1.25rem;
    line-height: 2;
  }
</style>
