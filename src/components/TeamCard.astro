---
import type { CollectionEntry } from 'astro:content';

interface Props {
  member: CollectionEntry<'team'>;
}

const { member } = Astro.props;
const {
  name, role, bio, degree,
  projectTitle, projectDescription,
  website, googleScholar, github, linkedin,
  photo, alumni, currentStatus,
} = member.data;
---

<article class="team-card">
  <div class="photo-wrap">
    {photo
      ? <img src={photo.src} alt={name} width="96" height="96" />
      : <span class="initials">{name.split(' ').map((n: string) => n[0]).join('')}</span>
    }
  </div>

  <div class="info">
    <h3 class="name">{name}</h3>
    {degree && <p class="degree">{degree}</p>}

    {projectTitle && (
      <p class="project-title">{projectTitle}</p>
    )}
    {projectDescription && (
      <p class="project-desc">{projectDescription}</p>
    )}

    {bio && <p class="bio">{bio}</p>}

    {alumni && currentStatus && (
      <div class="current-status">
        <span class="status-label">What I'm up to now:</span>
        <p>{currentStatus}</p>
      </div>
    )}

    <div class="links">
      {website       && <a href={website}       target="_blank" rel="noopener">Website</a>}
      {googleScholar && <a href={googleScholar}  target="_blank" rel="noopener">Scholar</a>}
      {github        && <a href={github}         target="_blank" rel="noopener">GitHub</a>}
      {linkedin      && <a href={linkedin}       target="_blank" rel="noopener">LinkedIn</a>}
    </div>
  </div>
</article>

<style>
  .team-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }

  .photo-wrap {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
  }

  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info { flex: 1; min-width: 0; }

  .name {
    margin: 0 0 0.2rem;
    font-size: 1rem;
  }

  .degree {
    margin: 0 0 0.5rem;
    font-size: 0.8rem;
    opacity: 0.6;
    font-style: italic;
  }

  .project-title {
    margin: 0 0 0.2rem;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .project-desc {
    margin: 0 0 0.6rem;
    font-size: 0.85rem;
    line-height: 1.5;
    opacity: 0.8;
  }

  .bio {
    margin: 0 0 0.6rem;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .current-status {
    margin: 0.5rem 0 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 6px;
    background: #f9fafb;
    font-size: 0.85rem;
  }

  .current-status p { margin: 0.2rem 0 0; line-height: 1.5; }

  .status-label {
    font-size: 0.75rem;
    font-weight: 600;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .links {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .links a {
    font-size: 0.78rem;
    text-decoration: none;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: #f3f4f6;
  }

  .links a:hover { background: #e5e7eb; }
</style>
