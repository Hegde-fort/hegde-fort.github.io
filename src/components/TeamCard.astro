---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';
import { buildTenure, buildLinks, buildInitials } from '../lib/team';

interface Props {
  member: CollectionEntry<'team'>;
  size?: 'large' | 'default';
}

const { member, size = 'default' } = Astro.props;
const { name, bio, projects, photo } = member.data;

const initials    = buildInitials(name);
const tenure      = buildTenure(member.data);
const links       = buildLinks(member.data);
const profileSlug = member.id.replace(/\/index$/, '');
---

<article class:list={['team-card', `team-card--${size}`]}>
  <div class="photo-wrap">
    {photo
      ? <Image src={photo} alt={name} />
      : <span class="initials" aria-hidden="true">{initials}</span>
    }
  </div>

  <div class="info">
    <h3 class="name">{name}</h3>
    {tenure && <p class="tenure">{tenure}</p>}
    {projects && projects.length > 0
      ? <ul class="project-list">
          {projects.map(p => (
            <li class="project-label"><span class="project-prefix">Project:</span> {p.title}</li>
          ))}
        </ul>
      : bio && <p class="bio-preview">{bio}</p>
    }

    <a class="read-more-link" href={`/team/${profileSlug}`}>Read more</a>

    {links.length > 0 && (
      <div class="links" aria-label="Profile links">
        {links.map(link => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="link-icon"
            aria-label={link.label}
            title={link.label}
          >
            <Icon name={link.icon} />
          </a>
        ))}
      </div>
    )}
  </div>
</article>


<style>
  .team-card {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-8);
    align-items: flex-start;
    padding: var(--space-6) 0;
  }

  .team-card--large { grid-template-columns: 120px 1fr; }

  /* photo */
  .photo-wrap {
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-accent);
    background: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--color-accent);
  }

  .team-card--default .photo-wrap { width: 72px;  height: 72px;  font-size: 1.2rem; }
  .team-card--large   .photo-wrap { width: 108px; height: 108px; font-size: 1.7rem; }

  .photo-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* info */
  .info {
    flex: 1;
    min-width: 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .name {
    margin: 0 0 0.15rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.2;
  }
  .team-card--default .name { font-size: 1.15rem; }
  .team-card--large   .name { font-size: 1.3rem; }

  .tenure {
    margin: 0 0 var(--space-2);
    font-size: 0.78rem;
    font-style: italic;
    color: rgba(15, 23, 42, 0.45);
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .project-label {
    margin: 0;
    font-size: 0.76rem;
    color: rgba(15, 23, 42, 0.7);
  }

  .project-prefix {
    font-weight: 700;
    color: var(--color-link);
  }

  .bio-preview {
    margin: 0 0 var(--space-2);
    font-size: 0.76rem;
    line-height: 1.5;
    color: rgba(15, 23, 42, 0.65);
    display: -webkit-box;
    -webkit-line-clamp: 10;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .read-more-link:hover { opacity: 0.7; }

  /* link icons */
  .links { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-4); }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    background: rgba(15, 23, 42, 0.05);
    color: rgba(15, 23, 42, 0.45) !important;
    text-decoration: none !important;
    transition: background 0.15s, color 0.15s;
  }

  .link-icon:hover {
    background: var(--color-accent);
    color: #0f172a !important;
  }

  .link-icon svg { width: 14px; height: 14px; }

  @media (max-width: 640px) {
    .team-card {
      grid-template-columns: 80px 1fr;
      gap: var(--space-3);
    }
    .team-card--default .photo-wrap { width: 80px; height: 80px; }
    .team-card--large   .photo-wrap { width: 80px; height: 80px; font-size: 1.2rem; }
  }
</style>
