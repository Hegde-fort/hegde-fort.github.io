---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pub: CollectionEntry<'publications'>;
  compact?: boolean;
}

const { pub, compact = false } = Astro.props;
const { title, authors, venue, year, url } = pub.data;
---

<article class:list={['pub-card', { 'pub-card--compact': compact }]}>
  <h3 class="title">{title}</h3>
  <p class="authors">{authors.join(', ')}</p>
  <p class="venue">{venue} · {year}</p>
  {url && <a class="read-link" href={url} target="_blank" rel="noopener">Read paper</a>}
</article>

<style>
  .pub-card {
    background: #ffffff;
    border-radius: var(--radius-card);
    border-left: 8px solid var(--color-accent);
    padding: var(--space-6) var(--space-8);
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .pub-card:hover {
    box-shadow: 0 4px 16px rgba(15, 23, 42, 0.1);
    transform: translateY(-1px);
  }

  /* ── Compact (home page grid) ──────────────────────────────── */
  .pub-card--compact {
    border-radius: 0;
    border-left: none;
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
    background: transparent;
    box-shadow: none;
    transform: none;
  }

  .pub-card--compact:hover { box-shadow: none; transform: none; }
  .pub-card--compact .title { font-size: 0.95rem; }

  /* ── Shared ────────────────────────────────────────────────── */
  .title {
    margin: 0 0 var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: #0f172a;
  }

  .authors {
    margin: 0 0 0.2rem;
    font-size: 0.85rem;
    color: rgba(15, 23, 42, 0.55);
    line-height: 1.4;
  }

  .venue {
    margin: 0 0 var(--space-3);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-link);
  }

  /* .read-link global in Layout.astro */

  @media (max-width: 640px) {
    .pub-card {
      padding: var(--space-4) var(--space-6);
    }
  }
</style>
