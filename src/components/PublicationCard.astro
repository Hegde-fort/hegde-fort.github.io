---
import type { CollectionEntry } from 'astro:content';

interface Props {
  pub: CollectionEntry<'publications'>;
  /** Compact grid card used on the home page */
  compact?: boolean;
}

const { pub, compact = false } = Astro.props;
const { title, authors, venue, year, url, pdf, code, tags } = pub.data;
---

<article class:list={['pub-card', { 'pub-card--compact': compact }]}>
  <!-- Title is plain text — "Read paper" below is the CTA -->
  <h3 class="title">{title}</h3>

  <p class="authors">{authors.join(', ')}</p>
  <p class="venue">{venue} · {year}</p>

  {!compact && tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  )}

  <div class="links">
    {url  && <a class="read-link" href={url}  target="_blank" rel="noopener">Read paper</a>}
    {!compact && pdf  && <a href={pdf}  target="_blank" rel="noopener">PDF</a>}
    {!compact && code && <a href={code} target="_blank" rel="noopener">Code</a>}
  </div>
</article>

<style>
  /* ── Base ──────────────────────────────────────────────────── */
  .pub-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Compact (home page grid) ──────────────────────────────── */
  .pub-card--compact {
    border-bottom: none;
    padding: 0;
  }

  .pub-card--compact .title {
    font-size: 1rem;
    font-weight: 700;
  }

  /* ── Shared ────────────────────────────────────────────────── */
  .title {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    line-height: 1.4;
  }

  .title a { text-decoration: none; }
  .title a:hover { text-decoration: underline; }

  .authors, .venue {
    margin: 0 0 0.3rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.5rem 0;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
  }

  .links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  /* .read-link styles live in Layout.astro (global) */

  .links a:not(.read-link) {
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
  }
</style>
