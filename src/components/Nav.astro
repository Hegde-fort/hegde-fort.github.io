---
interface Props {
  labName: string;
}

const { labName } = Astro.props;

const navLinks = [
  { label: 'About Us',      href: '/about' },
  { label: 'Team',          href: '/team' },
  { label: 'Projects',      href: '/projects' },
  { label: 'Publications',  href: '/publications' },
  { label: 'News',          href: '/news' },
];

const currentPath = Astro.url.pathname;
---

<div class="nav-wrapper">
  <nav>
    <a class="nav-logo" href="/">
      <img src="/FORTLogo.png" alt={labName} class="nav-logo-img" />
      <span>{labName}</span>
    </a>

    <ul class="nav-links">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { active: currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: transparent;
    transition: background 0.25s ease, backdrop-filter 0.25s ease;
  }

  .nav-wrapper.scrolled {
    background: rgba(4, 23, 38, 0.75);  /* --color-bg-dark at 75% opacity */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--content-pad-x);
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--color-accent);
  }

  .nav-logo-img {
    height: 2.2rem;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
    font-size: 0.95rem;
  }

  .nav-link.active {
    font-weight: 600;
    color: var(--color-accent);
  }
</style>

<script>
  const nav = document.querySelector('.nav-wrapper') as HTMLElement;

  function update() {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }

  update();
  window.addEventListener('scroll', update, { passive: true });
</script>
