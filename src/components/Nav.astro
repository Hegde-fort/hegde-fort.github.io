---
interface Props {
  labName: string;
}

const { labName } = Astro.props;

const navLinks = [
  { label: 'About Us',      href: '/about' },
  { label: 'Team',          href: '/team' },
  { label: 'Projects',      href: '/projects' },
  { label: 'Publications',  href: '/publications' },
  { label: 'News',          href: '/news' },
];

const currentPath = Astro.url.pathname;
---

<div class="nav-wrapper">
  <nav>
    <a class="nav-logo" href="/">
      <!-- TODO: replace with lab logo/wordmark image -->
      <span>{labName}</span>
    </a>

    <ul class="nav-links">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { active: currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: #1A3A6B;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--content-pad-x);
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
    font-size: 0.95rem;
  }

  .nav-link.active {
    font-weight: 600;
    color: var(--color-accent);
  }
</style>
