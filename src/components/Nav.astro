---
import { getEntry } from 'astro:content';

interface Props {
  labName: string;
}

const { labName } = Astro.props;

const lab = (await getEntry('site', 'lab'))!.data;

const defaultLinks = [
  { label: 'About Us',     href: '/about',        hidden: false },
  { label: 'Team',         href: '/team',         hidden: false },
  { label: 'Projects',     href: '/projects',     hidden: false },
  { label: 'Publications', href: '/publications', hidden: false },
  { label: 'News',         href: '/news',         hidden: false },
];

const navLinks = (lab.nav ?? defaultLinks).filter(l => !l.hidden);

const currentPath = Astro.url.pathname;
---

<div class="nav-wrapper">
  <nav>
    <a class="nav-logo" href="/">
      <img src="/FORTLogo.png" alt={labName} class="nav-logo-img" />
      <span>{labName}</span>
    </a>

    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links" id="mobile-menu">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={['nav-link', { active: href === '/' ? currentPath === '/' : currentPath.startsWith(href) }]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: transparent;
    transition: background 0.25s ease, backdrop-filter 0.25s ease;
  }

  .nav-wrapper.scrolled {
    background: rgba(4, 23, 38, 0.75);  /* --color-bg-dark at 75% opacity */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--content-pad-x);
    height: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--color-accent);
  }

  .nav-logo-img {
    height: 2.2rem;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
    font-size: 0.95rem;
  }

  .nav-link.active {
    font-weight: 600;
    color: var(--color-accent);
  }

  /* ── Hamburger button ──────────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    z-index: 110;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text-on-dark);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Animate to X when open */
  .hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu ───────────────────────────────────────────── */
  @media (max-width: 700px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      gap: 0;
      position: fixed;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: rgba(4, 23, 38, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 1rem 0 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-links li {
      width: 100%;
    }

    .nav-link {
      display: block;
      padding: 0.85rem var(--content-pad-x);
      font-size: 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
  }
</style>

<script>
  function initNav() {
    const nav = document.querySelector('.nav-wrapper') as HTMLElement | null;
    const hamburger = document.querySelector('.hamburger') as HTMLButtonElement | null;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;

    if (!nav || !hamburger || !mobileMenu) return;

    // Scroll-based frosted glass
    function updateScroll() {
      nav!.classList.toggle('scrolled', window.scrollY > 20);
    }
    updateScroll();
    window.addEventListener('scroll', updateScroll, { passive: true });

    function closeMenu() {
      mobileMenu!.classList.remove('open');
      hamburger!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    function openMenu() {
      mobileMenu!.classList.add('open');
      hamburger!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    // Hamburger toggle
    hamburger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.contains('open');
      isOpen ? closeMenu() : openMenu();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });

    // Close menu when a link is clicked
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
