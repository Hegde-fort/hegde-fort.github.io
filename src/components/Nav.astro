---
const navLinks = [
  { label: 'About Us', href: '/about' },
  { label: 'Team',     href: '/team' },
  { label: 'Projects', href: '/projects' },
  { label: 'Publications', href: '/publications' },
  { label: 'News',     href: '/news' },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <a class="nav-logo" href="/">
    <!-- TODO: replace with lab logo/wordmark -->
    <span>FORT Lab</span>
  </a>

  <ul class="nav-links">
    {navLinks.map(({ label, href }) => (
      <li>
        <a
          href={href}
          class:list={['nav-link', { active: currentPath.startsWith(href) }]}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: inherit;
    font-size: 0.95rem;
  }

  .nav-link.active {
    font-weight: 600;
  }
</style>
