---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'news'>;
  compact?:  boolean;
  featured?: boolean;
}

const { item, compact = false, featured = false } = Astro.props;
const { title, date, summary, image, externalUrl } = item.data;

const href       = externalUrl ?? `/news/${item.id}`;
const isExternal = !!externalUrl;

const monthYear = date.toLocaleDateString('en-CA', { year: 'numeric', month: 'short' });
---

<article class:list={['news-card', {
  'news-card--compact':  compact,
  'news-card--featured': featured,
}]}>

  {/* ── Compact (home page hero) ───────────────────────── */}
  {compact && (
    <>
      {image && (
        <a class="thumb-link" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          <img class="news-thumb" src={image.src} alt={title} />
        </a>
      )}
      <div class="news-body">
        <h3 class="title">{title}</h3>
        <p class="summary">{summary}</p>
        <a class="read-link" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          Read Article
        </a>
      </div>
    </>
  )}

  {/* ── Featured (top of /news) ─────────────────────────── */}
  {featured && (
    <div class="featured-inner">
      {image && (
        <a class="featured-img-wrap" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          <img src={image.src} alt={title} />
        </a>
      )}
      <div class="featured-body">
        <time datetime={date.toISOString()} class="date-pill">{monthYear}</time>
        <h2 class="featured-title">
          <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
            {title}
          </a>
        </h2>
        <p class="featured-summary">{summary}</p>
        <a class="read-link" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          Read Article
        </a>
      </div>
    </div>
  )}

  {/* ── Default grid card (/news listing) ──────────────── */}
  {!compact && !featured && (
    <>
      {image && (
        <a class="card-img-wrap" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          <img src={image.src} alt={title} />
        </a>
      )}
      <div class="card-body">
        <time datetime={date.toISOString()} class="date-pill">{monthYear}</time>
        <h3 class="card-title">
          <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
            {title}
          </a>
        </h3>
        <p class="card-summary">{summary}</p>
        <a class="read-link" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
          Read Article
        </a>
      </div>
    </>
  )}

</article>

<style>
  /* ══ COMPACT (home hero) ════════════════════════════════════ */
  .news-card--compact {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-4);
    background: var(--color-bg-light);
    border-radius: var(--radius-card);
  }

  .thumb-link { flex-shrink: 0; }

  .news-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .news-card--compact .news-body { flex: 1; min-width: 0; }

  .news-card--compact .title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-1);
    color: #0f172a;
  }

  .news-card--compact .summary {
    font-size: 0.85rem;
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: rgba(15, 23, 42, 0.65);
  }

  /* ══ FEATURED ════════════════════════════════════════════════ */
  .news-card--featured {
    background: #ffffff;
    border-radius: var(--radius-card);
    overflow: hidden;
    border-top: 4px solid var(--color-accent);
  }

  .featured-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .featured-img-wrap {
    display: block;
    overflow: hidden;
    min-height: 280px;
  }

  .featured-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .featured-img-wrap:hover img { transform: scale(1.03); }

  .featured-body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 1px solid rgba(15, 23, 42, 0.06);
  }

  .featured-title {
    margin: var(--space-3) 0 var(--space-3);
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .featured-title a { color: #0f172a; text-decoration: none; }
  .featured-title a:hover { color: var(--color-link); }

  .featured-summary {
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(15, 23, 42, 0.65);
    margin: 0 0 var(--space-5);
    flex: 1;
  }

  @media (max-width: 700px) {
    .featured-inner { grid-template-columns: 1fr; }
    .featured-img-wrap { min-height: 200px; }
    .featured-body { border-left: none; border-top: 1px solid rgba(15, 23, 42, 0.06); }
  }

  /* ══ DEFAULT GRID CARD ═══════════════════════════════════════ */
  .news-card:not(.news-card--compact):not(.news-card--featured) {
    background: #ffffff;
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border-top: 4px solid var(--color-accent);
    transition: transform 0.2s;
  }

  .news-card:not(.news-card--compact):not(.news-card--featured):hover {
    transform: translateY(-2px);
  }

  .card-img-wrap {
    display: block;
    overflow: hidden;
    height: 180px;
    flex-shrink: 0;
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .card-img-wrap:hover img { transform: scale(1.04); }

  .card-body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-title {
    margin: var(--space-2) 0 var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .card-title a { color: #0f172a; text-decoration: none; }
  .card-title a:hover { color: var(--color-link); }

  .card-summary {
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(15, 23, 42, 0.6);
    margin: 0 0 var(--space-4);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ══ SHARED ══════════════════════════════════════════════════ */
  .date-pill {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--color-accent);
    color: #0f172a;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
  }

  /* .read-link global in Layout.astro */
</style>
