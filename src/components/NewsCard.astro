---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'news'>;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
const { title, date, summary, image, externalUrl, tags } = item.data;

const href = externalUrl ?? `/news/${item.id}`;
const isExternal = !!externalUrl;

const formattedDate = date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class:list={['news-card', { 'news-card--compact': compact }]}>
  {image && (
    <a class="thumb-link" href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
      <img class="news-thumb" src={image.src} alt={title} />
    </a>
  )}

  <div class="news-body">
    {!compact && (
      <time datetime={date.toISOString()} class="date">{formattedDate}</time>
    )}

    <h3 class="title">
      <a
        href={href}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener' : undefined}
      >
        {title}
      </a>
    </h3>

    <p class="summary">{summary}</p>

    {compact && (
      <a
        class="read-link"
        href={href}
        target={isExternal ? '_blank' : undefined}
        rel={isExternal ? 'noopener' : undefined}
      >
        Read Article
      </a>
    )}

    {!compact && tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
</article>

<style>
  /* ── Base card ─────────────────────────────────────────────── */
  .news-card {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-6) 0;
  }

  /* ── Compact / hero variant ────────────────────────────────── */
  .news-card--compact {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-4);
    border-bottom: none;
    background: var(--color-bg-light);
    border-radius: var(--radius-card);
  }

  .thumb-link { flex-shrink: 0; }

  .news-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .news-card--compact .news-body { flex: 1; min-width: 0; }

  .news-card--compact .title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-1);
  }

  .news-card--compact .summary {
    font-size: 0.85rem;
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Default variant ───────────────────────────────────────── */
  .news-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
  }

  .date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.25rem;
  }

  .title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .title a { text-decoration: none; }
  .title a:hover { text-decoration: underline; }

  .summary {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .read-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-link);   /* always uses the blue link token, never --color-accent */
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .read-link:hover { opacity: 0.8; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-full);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
  }
</style>
