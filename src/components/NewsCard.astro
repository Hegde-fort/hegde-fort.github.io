---
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'news'>;
  compact?:  boolean;
  featured?: boolean;
}

const { item, compact = false, featured = false } = Astro.props;
const { title, date, summary, image, imageAlt, externalUrl } = item.data;

const href       = externalUrl ?? `/news/${item.id}`;
const isExternal = !!externalUrl;
const linkProps  = { href, target: isExternal ? '_blank' : undefined, rel: isExternal ? 'noopener noreferrer' : undefined };

const monthYear = date.toLocaleDateString('en-CA', { year: 'numeric', month: 'short' });
const altText   = imageAlt || title;
const imgSrc    = image?.src;
---

<article class:list={['news-card', {
  'news-card--compact':  compact,
  'news-card--featured': featured,
}]}>

  {/* ── Compact (home page hero panel) ─────────────────── */}
  {compact && (
    <>
      {image && (
        <a class="thumb-link" {...linkProps}>
          <img class="news-thumb" src={imgSrc} alt={altText} loading="lazy" />
        </a>
      )}
      <div class="news-body">
        <h3 class="title">
          <a {...linkProps}>{title}</a>
        </h3>
        <p class="summary">{summary}</p>
      </div>
    </>
  )}

  {/* ── Featured hero card (top of /news) ──────────────── */}
  {featured && (
    <a class="featured-link" {...linkProps}>
      <div class="featured-inner">
        <div class="featured-img-side">
          {imgSrc
            ? <img src={imgSrc} alt={altText} loading="eager" />
            : <div class="featured-img-placeholder" />}
        </div>
        <div class="featured-body">
          <time datetime={date.toISOString()} class="date-pill">{monthYear}</time>
          <h2 class="featured-title">{title}</h2>
          <p class="featured-summary">{summary}</p>
        </div>
      </div>
    </a>
  )}

  {/* ── Portrait grid card (3-up grid on /news) ────────── */}
  {!compact && !featured && (
    <a class="card-link" {...linkProps}>
      <div class="card-img-wrap">
        {imgSrc
          ? <img src={imgSrc} alt={altText} loading="lazy" />
          : <div class="card-img-placeholder" />}
      </div>
      <div class="card-body">
        <time datetime={date.toISOString()} class="date-pill">{monthYear}</time>
        <h3 class="card-title">{title}</h3>
        <p class="card-summary">{summary}</p>
      </div>
    </a>
  )}

</article>

<style>
  /* ══ COMPACT (home hero panel) ══════════════════════════════ */
  .news-card--compact {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-4);
    background: var(--color-bg-light);
    border-radius: var(--radius-md);
  }

  .thumb-link { flex-shrink: 0; }

  .news-thumb {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  .news-card--compact .news-body { flex: 1; min-width: 0; }

  .news-card--compact .title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 var(--space-1);
    line-height: 1.35;
  }

  .news-card--compact .title a {
    color: var(--color-text-on-white);
    text-decoration: none;
  }
  .news-card--compact .title a:hover { color: var(--color-link); }

  .news-card--compact .summary {
    font-size: 0.82rem;
    line-height: 1.5;
    color: rgba(4, 23, 38, 0.65);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  /* ══ FEATURED HERO CARD ══════════════════════════════════════ */
  .news-card--featured {
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-bg-dark);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
  }

  .featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .featured-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    min-height: 340px;
  }

  .featured-img-side {
    overflow: hidden;
    position: relative;
  }

  .featured-img-side img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .featured-link:hover .featured-img-side img {
    transform: scale(1.04);
  }

  .featured-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-link) 0%, #041726 100%);
  }

  .featured-body {
    padding: var(--space-10) var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
    border-left: 3px solid var(--color-accent);
  }

  .featured-title {
    margin: 0;
    font-size: clamp(1.25rem, 2.5vw, 1.7rem);
    font-weight: 800;
    line-height: 1.25;
    color: var(--color-text-on-dark);
    transition: color 0.2s;
  }

  .featured-link:hover .featured-title { color: var(--color-accent); }

  .featured-summary {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 700px) {
    .featured-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .featured-img-side { height: 220px; }
    .featured-body {
      border-left: none;
      border-top: 3px solid var(--color-accent);
      padding: var(--space-6);
    }
  }

  /* ══ PORTRAIT GRID CARD ══════════════════════════════════════ */
  .news-card:not(.news-card--compact):not(.news-card--featured) {
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .news-card:not(.news-card--compact):not(.news-card--featured):hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(4, 23, 38, 0.12);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    flex: 1;
    text-decoration: none;
    color: inherit;
  }

  .card-img-wrap {
    overflow: hidden;
    height: 195px;
    flex-shrink: 0;
    background: var(--color-bg-panel);
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .news-card:not(.news-card--compact):not(.news-card--featured):hover .card-img-wrap img {
    transform: scale(1.05);
  }

  .card-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-link) 0%, #d3e5e9 100%);
  }

  .card-body {
    padding: var(--space-5) var(--space-6) var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
    border-top: 4px solid var(--color-accent);
  }

  .card-title {
    margin: var(--space-3) 0 var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text-on-white);
    transition: color 0.2s;
  }

  .news-card:not(.news-card--compact):not(.news-card--featured):hover .card-title {
    color: var(--color-link);
  }

  .card-summary {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgba(4, 23, 38, 0.6);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ══ SHARED ══════════════════════════════════════════════════ */
  .date-pill {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    background: var(--color-accent);
    color: #041726;
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    width: fit-content;
  }
</style>
