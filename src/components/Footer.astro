---
interface Props {
  labName: string;
  affiliations: string[];
  github?: string;
}

const { labName, affiliations, github } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="lab-name">{labName}</p>

    {affiliations.map(a => (
      <p class="affiliation">{a}</p>
    ))}

    <div class="footer-links">
      {github && (
        <a href={github} target="_blank" rel="noopener">GitHub</a>
      )}
    </div>

    <p class="copyright">&copy; {currentYear} {labName}. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    padding: 3rem 2rem;
    margin-top: auto;
    text-align: center;
  }

  .footer-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: center;
  }

  .lab-name {
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
  }

  .affiliation {
    margin: 0;
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    margin: 0.5rem 0;
  }

  .footer-links a {
    text-decoration: none;
    font-size: 0.9rem;
  }

  .copyright {
    margin: 0;
    font-size: 0.8rem;
    opacity: 0.6;
  }
</style>
