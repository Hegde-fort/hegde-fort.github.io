---
interface Props {
  labName: string;
  affiliations: string[];
  nav?: { label: string; href: string; hidden?: boolean }[];
}

const { labName, affiliations, nav } = Astro.props;
const currentYear = new Date().getFullYear();

const defaultLinks = [
  { label: 'Home',         href: '/',              hidden: false },
  { label: 'About Us',     href: '/about',         hidden: false },
  { label: 'Team',         href: '/team',          hidden: false },
  { label: 'Publications', href: '/publications',  hidden: false },
  { label: 'News',         href: '/news',          hidden: false },
];

const navLinks = (nav ?? defaultLinks).filter(l => !l.hidden);
---

<footer class="surface-light">
  <!-- Stamp icon straddling the dark section above and white footer -->
  <div class="stamp-wrap">
    <div class="stamp">
      <img src="/FORTLogo.png" alt={labName + ' logo'} />
    </div>
  </div>

  <div class="footer-inner">
    <div class="footer-cols">
      <!-- Left: Quick navigation -->
      <div class="footer-col">
        <h3 class="col-heading">Explore</h3>
        <ul class="nav-list">
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Right: Affiliations -->
      <div class="footer-col">
        <h3 class="col-heading">Affiliations</h3>
        <ul class="affiliation-list">
          {affiliations.map(a => <li>{a}</li>)}
        </ul>
      </div>
    </div>

    <p class="copyright">&copy; {currentYear} {labName}. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: #ffffff;
    padding-top: 0;
  }

  /* ── Stamp ─────────────────────────────────────────────────── */
  .stamp-wrap {
    display: flex;
    justify-content: center;
    transform: translateY(-50%);
    margin-bottom: calc(-1 * var(--space-6));
  }

  .stamp {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-bg-dark);
    border: 4px solid #ffffff;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stamp img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Inner layout ─────────────────────────────────────────── */
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--content-pad-x) var(--space-10);
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 600px) {
    .footer-cols { grid-template-columns: 1fr; }
  }

  /* ── Column headings ──────────────────────────────────────── */
  .col-heading {
    margin: 0 0 var(--space-3);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  /* ── Quick nav list ───────────────────────────────────────── */
  .nav-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
  }

  .nav-list a {
    font-size: 0.9rem;
    color: var(--color-text-muted) !important;
    text-decoration: none !important;
    transition: color 0.15s ease;
  }

  .nav-list a:hover {
    color: var(--color-text-primary) !important;
  }

  /* ── Affiliations list ────────────────────────────────────── */
  .affiliation-list {
    margin: 0;
    padding: 0 0 0 var(--space-4);
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .affiliation-list li {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Copyright ────────────────────────────────────────────── */
  .copyright {
    margin: var(--space-6) 0 0;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
