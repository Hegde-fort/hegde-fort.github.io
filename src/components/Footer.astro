---
interface Props {
  labName: string;
  affiliations: string[];
}

const { labName, affiliations } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="lab-name">{labName}</p>

    {affiliations.map(a => (
      <p class="affiliation">{a}</p>
    ))}

    <p class="copyright">&copy; {currentYear} {labName}. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    padding: var(--space-12) var(--content-pad-x);
    margin-top: auto;
    text-align: center;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-surface);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }

  .lab-name {
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
  }

  .affiliation {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .copyright {
    margin: var(--space-3) 0 0;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
