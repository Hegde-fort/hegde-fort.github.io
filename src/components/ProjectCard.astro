---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  accent?: 'yellow' | 'blue' | 'gray';
}

const { project, accent = 'yellow' } = Astro.props;
const { title, summary, status, image, url, startDate, endDate } = project.data;

const fmt = (d: Date) => d.toLocaleDateString('en-CA', { year: 'numeric', month: 'short' });
const dateRange = endDate
  ? `${fmt(startDate)} – ${fmt(endDate)}`
  : `${fmt(startDate)} – Present`;
---

<article class:list={['project-card', `accent-${accent}`]}>
  {image && (
    <div class="card-img-wrap">
      <img src={image.src} alt={title} />
    </div>
  )}

  <div class="card-body">
    <div class="card-top">
      <span class:list={['status-badge', status]}>{status}</span>
      <span class="date-range">{dateRange}</span>
    </div>

    <h3 class="title">{title}</h3>
    <p class="summary">{summary}</p>

    {url && (
      <a class="project-link read-link" href={url} target="_blank" rel="noopener">
        View Project
      </a>
    )}
  </div>
</article>

<style>
  .project-card {
    background: #ffffff;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(15, 23, 42, 0.06);
    display: flex;
    flex-direction: column;
    border-top: 4px solid transparent;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .project-card:hover {
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.1);
    transform: translateY(-2px);
  }

  .accent-yellow { border-top-color: var(--color-accent); }
  .accent-blue   { border-top-color: var(--color-link); }
  .accent-gray   { border-top-color: rgba(15, 23, 42, 0.2); }

  .card-img-wrap {
    height: 160px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-body {
    padding: var(--space-5) var(--space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .status-badge {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-badge.active    { background: #d1fae5; color: #065f46; }
  .status-badge.completed { background: rgba(18, 63, 84, 0.1); color: var(--color-link); }
  .status-badge.archived  { background: rgba(15, 23, 42, 0.07); color: rgba(15, 23, 42, 0.5); }

  .date-range {
    font-size: 0.75rem;
    color: rgba(15, 23, 42, 0.4);
    font-style: italic;
  }

  .title {
    margin: 0 0 var(--space-2);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    color: #0f172a;
  }

  .summary {
    margin: 0 0 var(--space-4);
    font-size: 0.88rem;
    line-height: 1.55;
    color: rgba(15, 23, 42, 0.65);
    flex: 1;
  }

  /* .read-link global in Layout.astro */
  .project-link { align-self: flex-start; }
</style>
