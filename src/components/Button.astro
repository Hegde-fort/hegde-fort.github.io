---
interface Props {
  href: string;
  variant?: 'solid' | 'outline';
  /** Stretches to full container width and uses pill radius */
  fullWidth?: boolean;
  class?: string;
  target?: '_blank' | '_self';
}

const { href, variant = 'solid', fullWidth = false, class: className, target } = Astro.props;
const rel = target === '_blank' ? 'noopener noreferrer' : undefined;
---

<a
  href={href}
  target={target}
  rel={rel}
  class:list={[
    variant === 'solid' ? 'btn' : 'btn-outline',
    { 'btn--full': fullWidth },
    className,
  ]}
>
  <slot />
</a>

<style>
  /* Full-width pill variant (e.g. "Browse All News" in the hero panel) */
  .btn--full {
    display: block;
    width: 100%;
    text-align: center;
    border-radius: var(--radius-full);
  }
</style>
